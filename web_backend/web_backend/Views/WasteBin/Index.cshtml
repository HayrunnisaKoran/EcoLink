@model IEnumerable<web_backend.Models.WasteBin>

@{
    ViewData["Title"] = "At²k ▄niteleri";
}

<h2>At²k ▄niteleri ve Canl² Harita</h2>

<div id="map" style="height: 450px; width: 100%; margin-bottom: 20px; border: 2px solid #28a745; border-radius: 10px;"></div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>At²k T³r³</th>
            <th>Doluluk Oran²</th>
            <th>Durum</th>
            <th>Koordinatlar</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.WasteBinId</td>
                <td>@item.WasteType?.TypeName</td>
                <td>%@item.FillLevelPercent</td>
                <td>@(item.IsActive ? "Aktif" : "Pasif")</td>
                <td>@item.Latitude , @item.Longitude</td>
            </tr>
        }
    </tbody>
</table>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    // 1. Haritay² MCB▄ Muradiye Kamp³s³ koordinatlar²na odakla
    var map = L.map('map').setView([38.612, 27.278], 15);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '® OpenStreetMap'
    }).addTo(map);

    // 2. yaz²lan API'den verileri ńek
    fetch('/api/WasteBin/all')
        .then(response => response.json())
        .then(bins => {
            bins.forEach(bin => {
                // Her kutu ińin haritaya bir marker ekle
                var marker = L.marker([bin.latitude, bin.longitude]).addTo(map);
                marker.bindPopup(`
                    <b>${bin.wasteTypeName} Kutusu</b><br>
                    Doluluk: %${bin.fillLevelPercent}<br>
                    Durum: ${bin.isActive ? 'Aktif' : 'Pasif'}
                `);
            });
        });
</script>