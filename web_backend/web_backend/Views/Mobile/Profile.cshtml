@{
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
    ViewData["Title"] = "Profil";
}

<header class="mobile-top">
    <div class="brand">
        <a href="/Mobile" class="logo back">←</a>
        <div>
            <h1>Profil</h1>
            <p>Kullanıcı özeti</p>
        </div>
    </div>
</header>

<section class="card profile-card">
    <div class="big-avatar">A</div>

    <h2>Ayşe Demir</h2>
    <p>Hasan Ferdi Turgutlu Teknoloji Fakültesi</p>

    <div class="hero-stats" style="margin-top: 18px;">
        <div class="hero-stat" style="background: var(--green-100); color: var(--green-900);">
            <span>EcoPoint</span>
            <strong>1.250</strong>
        </div>

        <div class="hero-stat" style="background: var(--green-100); color: var(--green-900);">
            <span>Seviye</span>
            <strong>Yeşil 3</strong>
        </div>
    </div>
</section>

<div class="section-title">
    <h3>Seviye İlerlemesi</h3>
</div>

<section class="card">
    <div class="list-item">
        <div class="list-icon">🌿</div>
        <div>
            <h4>Yeşil 4 seviyesine ilerleme</h4>
            <p>1.250 / 1.500 EcoPoint</p>
            <div class="progress" style="margin-top: 10px;">
                <span style="width: 83%;"></span>
            </div>
        </div>
        <strong class="point">%83</strong>
    </div>
</section>

<div class="section-title">
    <h3>Katkı Özeti</h3>
</div>

<section class="list">
    <div class="list-item">
        <div class="list-icon">🗑️</div>
        <div>
            <h4>Toplam Atık Kaydı</h4>
            <p>Bu ay yapılan kayıt</p>
        </div>
        <strong class="point">32</strong>
    </div>

    <div class="list-item">
        <div class="list-icon">🌱</div>
        <div>
            <h4>Kompost Katkısı</h4>
            <p>Organik atık döngüsü</p>
        </div>
        <strong class="point">7</strong>
    </div>

    <div class="list-item">
        <div class="list-icon">🏆</div>
        <div>
            <h4>Fakülte Sırası</h4>
            <p>Yeşil Lig içindeki konum</p>
        </div>
        <strong class="point">#4</strong>
    </div>
</section>

<nav class="bottom-nav">
    <a href="/Mobile">
        <span>🏠</span>
        Ana
    </a>
    <a href="/Mobile/Scan">
        <span>📷</span>
        Tara
    </a>
    <a href="/Mobile/Leaderboard">
        <span>🏆</span>
        Lig
    </a>
    <a href="/Mobile/Rewards">
        <span>🎁</span>
        Ödül
    </a>
    <a href="/Mobile/Profile" class="active">
        <span>👤</span>
        Profil
    </a>
</nav>