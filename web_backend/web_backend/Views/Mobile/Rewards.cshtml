@{
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
    ViewData["Title"] = "Ödüller";
}

<header class="mobile-top">
    <div class="brand">
        <a href="/Mobile" class="logo back">←</a>
        <div>
            <h1>Ödüller</h1>
            <p>Rozet ve hedefler</p>
        </div>
    </div>
</header>

<section class="hero">
    <p class="hero-kicker">Rozet durumu</p>
    <h2>3 rozet kazandın</h2>

    <div class="hero-stats">
        <div class="hero-stat">
            <span>Toplam Puan</span>
            <strong>1.250</strong>
        </div>

        <div class="hero-stat">
            <span>Sonraki Hedef</span>
            <strong>1.500</strong>
        </div>
    </div>
</section>

<div class="section-title">
    <h3>Rozetlerim</h3>
</div>

<section class="reward-grid">
    <div class="reward-card">
        <div class="reward-icon">🌱</div>
        <h4>Yeşil Başlangıç</h4>
        <p>İlk atık kaydını tamamladın.</p>
    </div>

    <div class="reward-card">
        <div class="reward-icon">♻️</div>
        <h4>Dönüşüm Dostu</h4>
        <p>10 atık kaydı yaptın.</p>
    </div>

    <div class="reward-card">
        <div class="reward-icon">🏆</div>
        <h4>Lig Katılımcısı</h4>
        <p>Yeşil Lig sıralamasına girdin.</p>
    </div>

    <div class="reward-card locked">
        <div class="reward-icon">🔒</div>
        <h4>Kompost Ustası</h4>
        <p>5 organik atık katkısı gerekiyor.</p>
    </div>
</section>

<nav class="bottom-nav">
    <a href="/Mobile">
        <span>🏠</span>
        Ana
    </a>
    <a href="/Mobile/Scan">
        <span>📷</span>
        Tara
    </a>
    <a href="/Mobile/Leaderboard">
        <span>🏆</span>
        Lig
    </a>
    <a href="/Mobile/Rewards" class="active">
        <span>🎁</span>
        Ödül
    </a>
    <a href="/Mobile/Profile">
        <span>👤</span>
        Profil
    </a>
</nav>