@{
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
    ViewData["Title"] = "Atık Doğrulama";

    var binCode = ViewBag.BinCode as string ?? "KUTU-1023";
}

<header class="mobile-top">
    <div class="brand">
        <a href="/Mobile" class="logo back">←</a>
        <div>
            <h1>Atık Doğrulama</h1>
            <p>QR bağlantısı aktif</p>
        </div>
    </div>
</header>

<section class="card scan-hero">
    <div class="qr-visual">▦</div>

    <span class="pill">@binCode</span>

    <h2>Atık bilgini gir</h2>
    <p>Yarışma demosunda GPS, fotoğraf ve sensör kontrolü simüle edilir.</p>

    <form action="/Mobile/SubmitWaste" method="post" class="form">
        <input type="hidden" name="binCode" value="@binCode" />

        <label>Atık Türü</label>
        <select name="wasteType" class="input">
            <option value="Plastik">Plastik</option>
            <option value="Kağıt">Kağıt</option>
            <option value="Cam">Cam</option>
            <option value="Metal">Metal</option>
            <option value="Organik">Organik / Kompost</option>
        </select>

        <label>Miktar</label>
        <input type="number" step="0.1" min="0.1" name="amount" value="1" class="input" />

        <button type="submit" class="primary-btn">Doğrula ve EcoPoint Kazan</button>
    </form>
</section>

<div class="section-title">
    <h3>Güvenli Doğrulama</h3>
</div>

<section class="verify-grid">
    <div class="verify-item">
        <div class="verify-icon">📍</div>
        <div>
            <h4>GPS Kontrolü</h4>
            <p>Kutuya yakınlık doğrulanır.</p>
        </div>
        <span class="status">Hazır</span>
    </div>

    <div class="verify-item">
        <div class="verify-icon">📷</div>
        <div>
            <h4>Fotoğraf Kanıtı</h4>
            <p>Atık türü görsel olarak kontrol edilir.</p>
        </div>
        <span class="status">Hazır</span>
    </div>

    <div class="verify-item">
        <div class="verify-icon">📦</div>
        <div>
            <h4>Sensör Tokalaşması</h4>
            <p>Kutu doluluk değişimi simüle edilir.</p>
        </div>
        <span class="status">Hazır</span>
    </div>
</section>

<nav class="bottom-nav">
    <a href="/Mobile">
        <span>🏠</span>
        Ana
    </a>
    <a href="/Mobile/Scan" class="active">
        <span>📷</span>
        Tara
    </a>
    <a href="/Mobile/Leaderboard">
        <span>🏆</span>
        Lig
    </a>
    <a href="/Mobile/Rewards">
        <span>🎁</span>
        Ödül
    </a>
    <a href="/Mobile/Profile">
        <span>👤</span>
        Profil
    </a>
</nav>