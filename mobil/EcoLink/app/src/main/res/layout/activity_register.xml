<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8F2"> <!-- Temana uygun açık yeşil arka plan -->

    <!-- İsteğe bağlı: Arka planda login ekranındaki gibi yaprak deseni olsun istersen -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_main"
        android:alpha="0.2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Üst Logo / Başlık Alanı -->
            <TextView
                android:id="@+id/tvLogoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EcoLink"
                android:textColor="#2D5A27"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginTop="50dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Beyaz Kayıt Kutusu -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="30dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvLogoText"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:id="@+id/tvRegisterTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Yeni Hesap Oluştur"
                        android:textColor="#1A1A1A"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="Doğaya katkı sağlamak için hemen katılın."
                        android:textColor="#757575"
                        android:textSize="12sp"
                        android:layout_marginBottom="24dp"/>

                    <!-- Ad Soyad Kutusu -->
                    <EditText
                        android:id="@+id/etRegName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/tab_bg"
                        android:hint="Ad Soyad"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <!-- E-posta Kutusu -->
                    <EditText
                        android:id="@+id/etRegEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/tab_bg"
                        android:hint="Öğrenci E-posta (@ogr.cbu.edu.tr)"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Şifre Kutusu -->
                    <EditText
                        android:id="@+id/etRegPass"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/tab_bg"
                        android:hint="Şifre"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="24dp"/>

                    <!-- Kayıt Butonu -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegisterSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Kayıt Ol ve Başla"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        app:backgroundTint="#417D46"
                        app:cornerRadius="12dp" />

                    <!-- Girişe Dön Tuşu -->
                    <TextView
                        android:id="@+id/tvBackToLogin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Zaten hesabınız var mı? Giriş Yap"
                        android:textColor="#2D5A27"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>