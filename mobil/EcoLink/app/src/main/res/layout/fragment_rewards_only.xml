<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFBFA"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- MAĞAZA BAŞLIĞI -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EcoPoint Mağazası"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Biriktirdiğin puanları kampüste harca!"
            android:textColor="#757575"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"/>

        <!-- YAN YANA KAYDIRILABİLİR KARTLAR BÖLÜMÜ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- 1. KART: KANTİN & YEMEKHANE (250 Puan) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#F1F8F4"
                    app:strokeWidth="1dp"
                    app:strokeColor="#A5D6A7"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingVertical="20dp"
                        android:paddingHorizontal="12dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍽️" android:textSize="32sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Kantin &amp; Yemekhane" android:textColor="#388E3C" android:textStyle="bold" android:textSize="11sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="%20 İndirim Kuponu" android:textColor="#1A1A1A" android:textSize="12sp" android:gravity="center" android:layout_marginTop="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="250 Puan" android:textColor="#FFFFFF" android:background="#4CAF50" android:paddingHorizontal="16dp" android:paddingVertical="6dp" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. KART: ÜNİVERSİTE STORE (500 Puan) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FFFDF2"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FFE082"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingVertical="20dp"
                        android:paddingHorizontal="12dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎒" android:textSize="32sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Üniversite Store" android:textColor="#F57F17" android:textStyle="bold" android:textSize="11sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EcoLink Çanta, Matara" android:textColor="#1A1A1A" android:textSize="12sp" android:gravity="center" android:layout_marginTop="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="500 Puan" android:textColor="#1A1A1A" android:background="#FFCA28" android:paddingHorizontal="16dp" android:paddingVertical="6dp" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. KART: KAMPÜS HİZMETLERİ (750 Puan) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#E3F2FD"
                    app:strokeWidth="1dp"
                    app:strokeColor="#90CAF9"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingVertical="20dp"
                        android:paddingHorizontal="12dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎟️" android:textSize="32sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Kampüs Hizmetleri" android:textColor="#1976D2" android:textStyle="bold" android:textSize="11sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VIP Etkinlik, Rezervasyon" android:textColor="#1A1A1A" android:textSize="12sp" android:gravity="center" android:layout_marginTop="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="750 Puan" android:textColor="#FFFFFF" android:background="#2196F3" android:paddingHorizontal="16dp" android:paddingVertical="6dp" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. KART: SOSYAL SORUMLULUK (1000 Puan) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#F3E5F5"
                    app:strokeWidth="1dp"
                    app:strokeColor="#CE93D8"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingVertical="20dp"
                        android:paddingHorizontal="12dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌳" android:textSize="32sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Sosyal Sorumluluk" android:textColor="#7B1FA2" android:textStyle="bold" android:textSize="11sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TEMA Fidan Bağışı" android:textColor="#1A1A1A" android:textSize="12sp" android:gravity="center" android:layout_marginTop="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="1000 Puan" android:textColor="#FFFFFF" android:background="#9C27B0" android:paddingHorizontal="16dp" android:paddingVertical="6dp" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- BİLGİLENDİRME NOTU -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="*EcoPoint'ler kampüs içi iş birlikleri ile sürekli güncellenen ödül havuzunda kullanılabilir."
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:textStyle="italic"
            android:gravity="center" />

        <!-- KAZANILAN ROZETLER BÖLÜMÜ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Kazanılan ve Hedeflenen Rozetler"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <!-- Rozet 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#4CAF50"
                app:cardBackgroundColor="#F1F8F2"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:padding="12dp" android:orientation="vertical">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_rewards" app:tint="#FBC02D"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="İlk Adım" android:textStyle="bold" android:textColor="#1A1A1A"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10 Puan" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Kazanıldı ✓" android:textColor="#4CAF50" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rozet 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:padding="12dp" android:orientation="vertical">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_leaf" app:tint="#4CAF50"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Doğa Dostu" android:textStyle="bold" android:textColor="#1A1A1A"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hedef: 100 Puan" android:textSize="11sp" android:textColor="#757575"/>
                    <ProgressBar android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="12dp" android:progress="70" android:progressTint="#4CAF50" style="@android:style/Widget.ProgressBar.Horizontal" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>
    </LinearLayout>
</ScrollView>