<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    tools:context=".PhotoCaptureActivity">

    <!-- ARKA PLAN KAMERA GÖRÜNTÜSÜ (Burası ileride Kotlin ile kameraya bağlanacak) -->
    <!-- Şimdilik boş bir alan olarak kalıyor, siyah arka plan kamerayı temsil ediyor -->

    <!-- ÜST BAR (Başlık ve Geri Tuşu Beyaz) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="@null"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_take_photo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ÜST BİLGİ KARTLARI (Yarı Saydam Siyah ve Yeşil) -->
    <LinearLayout
        android:id="@+id/llTopInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        android:layout_marginTop="8dp">

        <!-- Fotoğraf Çekim Talimatı -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#CC202020"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_camera"
                    app:tint="#FFFFFF"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/inst_photo_top"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Konum Doğrulama Kutusu -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#CC417D46"
            app:cardElevation="0dp"/>
    </LinearLayout>

    <!-- ODAKLANMA (FOCUS) ÇERÇEVESİ -->

    <!-- ALT KONTROL ALANI (Zoom, Durum ve Kamera Butonları) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/focusFrame"
        android:layout_width="240dp"
        android:layout_height="320dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="24dp"
        app:layout_constraintBottom_toTopOf="@id/llBottomControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llTopInfo"
        app:layout_constraintVertical_bias="0.446"
        app:strokeColor="#C8E6C9"
        app:strokeWidth="2dp" />

    <LinearLayout
        android:id="@+id/llBottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:gravity="center_horizontal">

        <!-- Zoom 1x Göstergesi -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#80000000"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/zoom_1x"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:gravity="center"/>
        </com.google.android.material.card.MaterialCardView>



        <!-- Fotoğraf Netlik Durumu (Siyah Yarı Saydam Kutu) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#B3202020"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center_vertical">
                <androidx.cardview.widget.CardView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="1dp"
                    app:strokeColor="#4CAF50"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_done"
                        app:tint="#4CAF50"
                        android:contentDescription="@null"/>
                </androidx.cardview.widget.CardView>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_photo_ok"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_photo_sub"
                        android:textSize="11sp"
                        android:textColor="#BDBDBD"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Kamera Butonları (Flaş, Çekim, Döndür) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnFlash"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_flashlight"
                app:tint="#FFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:contentDescription="@null"/>

            <!-- Çekim Butonu (Büyük Beyaz Yuvarlak) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnCapture"
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardCornerRadius="36dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <!-- İçindeki küçük çerçeve -->
                <androidx.cardview.widget.CardView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="30dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="2dp"
                    app:strokeColor="#E0E0E0"
                    app:cardElevation="0dp"/>
            </androidx.cardview.widget.CardView>

            <ImageView
                android:id="@+id/btnFlipCamera"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_flip_camera"
                app:tint="#FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:contentDescription="@null"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>